# =============================================================================
# ClimaControl — variáveis de ambiente · ESTE ARQUIVO = API (servidor)
# -----------------------------------------------------------------------------
# O projeto tem 3 arquivos .env, um por subprojeto. Eles NÃO se unificam num só:
#   ../.env              → web    · lido pelo Vite   · prefixo VITE_*
#   ../mobile/.env       → mobile · lido pelo Expo   · prefixo EXPO_PUBLIC_*
#   api/.env     (este)  → API    · lido pelo dotenv · SEM prefixo
# Cada ferramenta lê o .env da PRÓPRIA pasta — por isso ficam separados.
#
# >>> ESTE É O ARQUIVO SECRETO. <<<  Roda só no servidor e NUNCA vai pro bundle
# da web/mobile. Mantenha-o SEPARADO dos .env do web/mobile de propósito: aqui
# fica a chave de admin do Firebase, que ignora as Security Rules e dá acesso
# total ao banco. Vazar isso = comprometer o projeto inteiro.
#
# Único valor compartilhado com web/mobile: FIREBASE_DATABASE_URL (mesma URL,
# que lá aparece como VITE_/EXPO_PUBLIC_FIREBASE_DATABASE_URL).
# =============================================================================

# ── Servidor ─────────────────────────────────────────────
PORT=3001
# Origens permitidas no CORS (separadas por vírgula). Use * em dev.
CORS_ORIGIN=http://localhost:5173,http://localhost:4173

# ── Firebase Admin SDK ───────────────────────────────────
# URL do Realtime Database (a mesma do app web: VITE_FIREBASE_DATABASE_URL)
FIREBASE_DATABASE_URL=https://seu-projeto-default-rtdb.firebaseio.com

# Credencial da conta de serviço (Service Account).
# No Render: cole o JSON INTEIRO do arquivo baixado em UMA linha nesta variável.
# Console Firebase → Configurações do projeto → Contas de serviço → Gerar nova chave privada.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}

# Alternativa local: caminho para o arquivo .json da conta de serviço
# (use ISTO ou a variável acima, não os dois). Em dev é mais cômodo.
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json
