# =============================================================================
# ClimaControl — variáveis de ambiente · ESTE ARQUIVO = MOBILE (Expo)
# -----------------------------------------------------------------------------
# O projeto tem 3 arquivos .env, um por subprojeto. Eles NÃO se unificam num só:
#   ../.env              → web    · lido pelo Vite   · prefixo VITE_*
#   mobile/.env  (este)  → mobile · lido pelo Expo   · prefixo EXPO_PUBLIC_*
#   ../api/.env          → API    · lido pelo dotenv · SEM prefixo (segredos)
# Cada ferramenta lê o .env da PRÓPRIA pasta — por isso ficam separados.
#
# Os valores EXPO_PUBLIC_FIREBASE_* abaixo são os MESMOS do web (lá com o prefixo
# VITE_FIREBASE_*). Só muda o prefixo; preencha uma vez e copie.
#
# ATENCAO: tudo que começa com EXPO_PUBLIC_ é EMBUTIDO no APK (qualquer um lê).
# Não coloque segredos aqui. A API key web do Firebase pode ficar exposta —
# quem protege são as Security Rules. Segredos de servidor ficam SÓ em api/.env.
# =============================================================================

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=

# false = conecta ao Realtime Database real (default).
# true  = força modo simulação (útil em demos sem hardware).
# Se faltar EXPO_PUBLIC_FIREBASE_API_KEY, o app cai em mock automaticamente.
EXPO_PUBLIC_USE_MOCK_DATA=false

# true só em dev — pula a tela de login.
EXPO_PUBLIC_SKIP_AUTH=false
