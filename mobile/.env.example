# =============================================================================
# ClimaControl — variáveis de ambiente · ESTE ARQUIVO = MOBILE (Expo)
# -----------------------------------------------------------------------------
# O app mobile lê os dados de um canal ThingSpeak (uplink do ESP32) e envia
# comandos de controle pela fila TalkBack. Cada ferramenta lê o .env da própria
# pasta:
#   ../.env              → web    · lido pelo Vite  · prefixo VITE_*
#   mobile/.env  (este)  → mobile · lido pelo Expo  · prefixo EXPO_PUBLIC_*
#
# ATENCAO: tudo que começa com EXPO_PUBLIC_ é EMBUTIDO no APK (qualquer um lê).
# As chaves do ThingSpeak ficam expostas — limitação conhecida de apps
# client-side; aceitável para o projeto acadêmico. Não reaproveite em nada
# sensível. (Em builds EAS os mesmos valores também podem ir em app.json → extra.)
# =============================================================================

# Canal de dados (uplink ESP → app).
EXPO_PUBLIC_THINGSPEAK_CHANNEL_ID=
EXPO_PUBLIC_THINGSPEAK_READ_KEY=

# Fila TalkBack (downlink app → ESP). Sem isso, o controle do A/C fica
# desabilitado (app só de leitura).
EXPO_PUBLIC_THINGSPEAK_TALKBACK_ID=
EXPO_PUBLIC_THINGSPEAK_TALKBACK_KEY=

# Nº de pontos do histórico (default 200).
EXPO_PUBLIC_THINGSPEAK_RESULTS=200

# false = conecta ao canal ThingSpeak real (default).
# true  = força modo simulação (útil em demos sem hardware).
# Se faltar EXPO_PUBLIC_THINGSPEAK_CHANNEL_ID/READ_KEY, cai em mock automaticamente.
EXPO_PUBLIC_USE_MOCK_DATA=false
