# =============================================================================
# ClimaControl — variáveis de ambiente · ESTE ARQUIVO = WEB (Vite)
# -----------------------------------------------------------------------------
# O dashboard web lê os dados de um canal ThingSpeak (uplink do ESP32) e envia
# comandos de controle pela fila TalkBack. Cada ferramenta lê o .env da própria
# pasta:
#   .env         (este)  → web    · lido pelo Vite  · prefixo VITE_*
#   mobile/.env          → mobile · lido pelo Expo  · prefixo EXPO_PUBLIC_*
#
# ATENCAO: tudo que começa com VITE_ é EMBUTIDO no bundle público (qualquer um
# lê no navegador). As chaves do ThingSpeak (Read Key e TalkBack Key) ficam
# expostas — é uma limitação conhecida de apps client-side no ThingSpeak e
# aceitável para um projeto acadêmico. Não reaproveite essas chaves em nada
# sensível.
# =============================================================================

# Canal de dados (uplink ESP → dashboard).
VITE_THINGSPEAK_CHANNEL_ID=
VITE_THINGSPEAK_READ_KEY=

# Fila TalkBack (downlink dashboard → ESP). Sem isso, o controle do A/C fica
# desabilitado (o dashboard vira só leitura).
VITE_THINGSPEAK_TALKBACK_ID=
VITE_THINGSPEAK_TALKBACK_KEY=

# Nº de pontos do histórico lidos do canal (default 200).
VITE_THINGSPEAK_RESULTS=200

# false = conecta ao canal ThingSpeak real (default).
# true  = força modo simulação (útil em demos sem hardware).
# Se faltar VITE_THINGSPEAK_CHANNEL_ID/READ_KEY, o app cai em mock automaticamente.
VITE_USE_MOCK_DATA=false
