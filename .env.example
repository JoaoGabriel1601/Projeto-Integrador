# =============================================================================
# ClimaControl — variáveis de ambiente · ESTE ARQUIVO = WEB (Vite)
# -----------------------------------------------------------------------------
# O projeto tem 3 arquivos .env, um por subprojeto. Eles NÃO se unificam num só:
#   .env         (este)  → web    · lido pelo Vite   · prefixo VITE_*
#   mobile/.env          → mobile · lido pelo Expo   · prefixo EXPO_PUBLIC_*
#   api/.env             → API    · lido pelo dotenv · SEM prefixo (segredos)
# Cada ferramenta lê o .env da PRÓPRIA pasta — por isso ficam separados.
#
# Os valores VITE_FIREBASE_* abaixo são os MESMOS do mobile (lá com o prefixo
# EXPO_PUBLIC_FIREBASE_*). Só muda o prefixo; preencha uma vez e copie.
#
# ATENCAO: tudo que começa com VITE_ é EMBUTIDO no bundle público (qualquer um
# lê no navegador). Não coloque segredos aqui. A API key web do Firebase pode
# ficar exposta — quem protege são as Security Rules (ver docs/FIREBASE_SETUP.md).
# Segredos de servidor (chave de admin) ficam SÓ em api/.env.
# =============================================================================

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_DATABASE_URL=

# false = conecta ao Realtime Database real (default).
# true  = força modo simulação (útil em demos sem hardware).
# Se faltar VITE_FIREBASE_API_KEY, o app cai em mock automaticamente.
VITE_USE_MOCK_DATA=false

# true só em dev — pula a tela de login.
VITE_SKIP_AUTH=false

# URL da API REST (gateway sobre o Firebase). Quando definida, as escritas de
# controle passam pela API. Em branco = escrita direta no Firebase.
# Local: http://localhost:3001 — Produção: https://climacontrol-api.onrender.com
VITE_API_URL=
