# Carregado automaticamente pelo Vite no `npm run build` (modo production).
# Tem prioridade sobre o .env, então o `npm run dev` continua usando localhost.
# Aqui só vão valores NÃO-secretos — as credenciais VITE_FIREBASE_* seguem no .env (ignorado pelo git).

# API REST publicada no Render.
VITE_API_URL=https://climacontrol-api.onrender.com

# Build de produção usa o Firebase real (não o mock).
VITE_USE_MOCK_DATA=false
